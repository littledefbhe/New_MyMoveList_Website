# Environment Variables Configuration
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control

# Flask Secret Key (REQUIRED)
# Generate a strong random key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# TMDB API Key (OPTIONAL - only needed for update_netflix_posters.py)
# Get free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here
